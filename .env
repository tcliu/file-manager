# File Manager Configuration
# Copy this to .env.local and customize

# Root directory to serve files from (default: current working directory)
# Also accepts FILE_MANAGER_ROOT_DIR as an env var fallback
# file-manager-root-dir=/path/to/files

# Authentication (leave password empty to disable auth)
# username=admin
# password=

# Session expiry in milliseconds (default: 3600000 = 1 hour)
session-expiry-ms=3600000

# Upload directory relative to root (default: upload)
upload-dir=upload

# Multiple root directories (comma-separated)
# root-dir=/path/to/dir1,/path/to/dir2

# Maximum total size for zip creation (supports B, KB, MB, GB, TB suffixes; default: 1GB)
max-zip-size=1GB

# Lightbox image load debounce in milliseconds
# When navigating between images/videos, the load is delayed until the index
# stays stable for this duration to avoid rapid reloading.
lightbox-load-debounce-ms=50

# Page switch debounce in milliseconds
# When switching pages, the load is delayed until the page index stays
# stable for this duration to avoid rapid reloading.
page-load-debounce-ms=200

# HTTP scheme: "http" or "https" (default: http)
# Set to "https" in .env.local to enable self-signed HTTPS for Vite preview
http-scheme=http
