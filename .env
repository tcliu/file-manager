# File Manager Configuration
# Copy this to .env.local and customize

# Root directory to serve files from (default: current working directory)
# FILE_MANAGER_ROOT_DIR=/path/to/files

# Authentication (leave PASSWORD empty to disable auth)
# USERNAME=admin
# PASSWORD=

# Session expiry in milliseconds (default: 3600000 = 1 hour)
# SESSION_EXPIRY_MS=3600000

# Upload directory relative to root (default: upload)
# UPLOAD_DIR=upload

# Multiple root directories (comma-separated)
# ROOT_DIR=/path/to/dir1,/path/to/dir2

# HTTP scheme: "http" or "https" (default: http)
# Set to "https" in .env.local to enable self-signed HTTPS for Vite preview
# HTTP_SCHEME=http
